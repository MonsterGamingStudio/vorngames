# For docker-compose.prod.yml (Postgres password used by compose + DATABASE_URL override)
POSTGRES_PASSWORD=change-me-in-production

# PM2 + docker-compose.postgres.yml (порт 5433 на хосте)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/vorn_games
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
STEAM_API_KEY=
STEAM_REALM=http://localhost:3000
STEAM_RETURN_URL=http://localhost:3000/api/auth/steam/callback
FRONTEND_URL=http://localhost:5173
PORT=3000
